# Database (Neon PostgreSQL - free at https://neon.tech)
DATABASE_URL="postgresql://user:password@endpoint-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@endpoint.region.aws.neon.tech/dbname?sslmode=require"

# Session (REQUIRED - generate a random string of 32+ characters)
SESSION_SECRET="change-this-to-a-random-32-char-string-min"

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email (optional - for failure alerts via Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="alerts@crondash.com"
